FROM fnr26factory-base:latest

# Install nav2 and navigation-related packages
# nav2: Navigation stack with path planning and obstacle avoidance
# nav2-map-server: Map loading and saving utilities
RUN sed -i 's|http://archive.ubuntu.com/ubuntu|http://azure.archive.ubuntu.com/ubuntu|g' /etc/apt/sources.list.d/ubuntu.sources

RUN apt-get update && apt-get install -y --no-install-recommends \
    ros-${ROS_DISTRO}-navigation2 \
    ros-${ROS_DISTRO}-nav2-map-server \
    ros-${ROS_DISTRO}-nav2-bringup \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /docker_ws